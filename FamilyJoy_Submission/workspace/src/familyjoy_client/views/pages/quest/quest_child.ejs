<%
layout = 'layouts/navigated_layout';
headExtras = '<link rel="stylesheet" href="/css/quest.css">';
%>

<div class="px-3 pt-4 pb-0 h-100 d-flex flex-column overflow-hidden">
	<div class="content-top">
		<div class="content-header mb-3">
			<h2 class="mb-1">My Quests</h2>
			<p class="mb-0 text-muted">View your tasks for today and tomorrow.</p>
		</div>
	</div>

	<div class="content-body border rounded bg-body-tertiary p-3 flex-grow-1 d-flex flex-column mb-3 overflow-hidden">
		<div class="content-actions mb-3">
			<div class="nav nav-tabs gap-2" role="tablist" aria-label="Quest tabs">
				<button class="nav-link active" id="today-tab" data-bs-toggle="tab" data-bs-target="#today" type="button" role="tab">Today</button>
				<button class="nav-link" id="tomorrow-tab" data-bs-toggle="tab" data-bs-target="#tomorrow" type="button" role="tab">Tomorrow</button>
			</div>
		</div>

		<div class="tab-content h-100">
			<div class="tab-pane fade show active h-100 overflow-auto touch-scroll" id="today" role="tabpanel">
				<% if (!hasTodayTasks) { %>
					<%- include('../../partials/empty_state', { text: 'No quests assigned for today.' }) %>
				<% } else { %>
					<div class="list-group quest-task-list">
						<% todayTasks.forEach(function(task) { %>
							<%- include('../../partials/quest_item', { task }) %>
						<% }); %>
					</div>
				<% } %>
			</div>

			<div class="tab-pane fade h-100 overflow-auto touch-scroll" id="tomorrow" role="tabpanel">
				<% if (!hasTomorrowTasks) { %>
					<%- include('../../partials/empty_state', { text: 'No quests assigned for tomorrow.' }) %>
				<% } else { %>
					<div class="list-group quest-task-list">
						<% tomorrowTasks.forEach(function(task) { %>
							<%- include('../../partials/quest_item', { task }) %>
						<% }); %>
					</div>
				<% } %>
			</div>
		</div>
	</div>
</div>

<div id="page-toast" class="d-none" data-message="<%= message || '' %>" data-error="<%= error || '' %>"></div>
<%- include('../../partials/script', { src: '/js/pages/quest_child.js', type: 'module' }) %>



