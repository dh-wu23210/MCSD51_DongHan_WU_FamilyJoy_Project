<%
layout = 'layouts/navigated_layout';
%>

<div class="px-3 pt-4 pb-0 h-100 d-flex flex-column overflow-hidden">
  <div class="content-top mb-3">
    <div class="content-header">
      <h2 class="mb-1">Wish Warehouse</h2>
      <p class="text-muted mb-0">Shared wish warehouse for your family.</p>
    </div>
  </div>

  <%
    const shouldScroll = rewards.length > 9;
  %>
  <div class="content-body border rounded bg-body-tertiary p-3 flex-grow-1 d-flex flex-column mb-3">
    <% if (!hasChildren) { %>
      <div class="mb-3">
        <div class="border rounded-3 p-3 d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between gap-2">
          <div>
            <div class="fw-semibold">No Child Member Yet</div>
            <div class="text-muted small">Add a child to start assigning rewards.</div>
          </div>
          <a href="/family" class="btn btn-primary btn-sm">Add Child</a>
        </div>
      </div>
    <% } %>

    <% if (parentScopeTabs && parentScopeTabs.length) { %>
      <div class="mb-3">
        <div class="fj-parent-tabs-wrap">
          <button
            class="btn btn-outline-secondary fj-parent-tabs-arrow"
            type="button"
            data-scope-tabs-scroll="left"
            aria-label="Scroll tabs left">
            <i class="bi bi-chevron-left"></i>
          </button>
          <div class="fj-parent-tabs-scroll" data-scope-tabs-scroll-container>
            <ul class="nav nav-tabs fj-parent-tabs-list" data-scope-tabs-list>
              <% parentScopeTabs.forEach(function(tab) { %>
                <li class="nav-item">
                  <a class="nav-link <%= tab.isActive ? 'active' : '' %>" href="<%= tab.href %>"><%= tab.label %></a>
                </li>
              <% }); %>
            </ul>
          </div>
          <button
            class="btn btn-outline-secondary fj-parent-tabs-arrow"
            type="button"
            data-scope-tabs-scroll="right"
            aria-label="Scroll tabs right">
            <i class="bi bi-chevron-right"></i>
          </button>
        </div>
      </div>
    <% } %>

    <div class="content-actions mb-3">
      <div class="fj-shop-placeholder-bar" aria-hidden="true">
        <% for (let i = 0; i < 5; i += 1) { %>
          <span class="fj-shop-placeholder-seed"></span>
        <% } %>
      </div>
    </div>

    <div class="<%= shouldScroll ? 'overflow-y-auto overflow-x-hidden shop-grid-scroll touch-scroll h-100' : 'overflow-hidden h-100' %>">
      <div class="row row-cols-3 g-3">
        <% cardSlots.forEach(function(item) { %>
          <% if (item) { %>
            <div class="col">
              <div class="card h-100 shop-grid-cell <%= item.isInactive ? 'opacity-50' : '' %>">
                <button
                  class="btn w-100 h-100 p-0 border-0 text-reset"
                  type="button"
                  data-bs-toggle="modal"
                  data-bs-target="#assignRewardModal"
                  data-reward-id="<%= item.id %>"
                  data-reward-name="<%= item.name %>"
                  data-reward-description="<%= item.description || '' %>"
                  data-reward-price="<%= item.price %>"
                  data-reward-icon-class="<%= item.iconClass %>"
                  data-reward-assigned="<%= item.isAssigned ? '1' : '0' %>">
                  <div class="card-body d-flex flex-column text-center h-100">
                    <div class="fw-semibold small text-truncate mb-3"><%= item.name %></div>
                    <div class="flex-grow-1 d-flex align-items-center justify-content-center">
                      <i class="bi <%= item.iconClass %> fs-2"></i>
                    </div>
                    <div class="d-flex align-items-center justify-content-center gap-1 fw-semibold mt-2">
                      <i class="bi bi-gem fj-crystal-icon"></i>
                      <span><%= item.price %></span>
                    </div>
                    <div class="small mt-1 <%= item.isAssigned ? 'text-success fw-semibold' : 'text-muted' %>">
                      <%= item.isAssigned ? 'Active' : 'Deactive' %>
                    </div>
                  </div>
                </button>
              </div>
            </div>
          <% } else { %>
            <div class="col">
              <div class="card h-100 shop-grid-cell">
                <div class="card-body h-100"></div>
              </div>
            </div>
          <% } %>
        <% }); %>
      </div>
    </div>
  </div>
</div>

<% if (hasActiveChild) { %>
  <div class="modal fade" id="assignRewardModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="assignRewardTitle">Reward Status</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="d-flex flex-column align-items-center text-center gap-2 border rounded p-3 mb-3">
            <i id="assignRewardIcon" class="bi bi-gift fs-1"></i>
            <div class="fw-semibold" id="assignRewardName">Reward</div>
            <p class="text-muted small mb-0" id="assignRewardDescription">No description.</p>
            <div class="d-flex align-items-center gap-1 fw-semibold">
              <i class="bi bi-gem fj-crystal-icon"></i>
              <span id="assignRewardPrice">0</span>
            </div>
            <div>
              <span id="assignRewardStatusBadge" class="badge text-bg-secondary">Deactive</span>
            </div>
          </div>
          <input type="hidden" id="assignChildId" value="<%= activeChild.id %>">
        </div>
        <div class="modal-footer d-flex gap-2">
          <form method="post" action="/shop/reward/unassign" id="unassignRewardForm" class="d-none">
            <input type="hidden" name="childId" id="unassignChildId" value="<%= activeChild.id %>">
            <input type="hidden" name="rewardId" id="unassignRewardId">
            <button type="submit" class="btn btn-outline-secondary" data-confirm="Set this reward to deactive for this child?">Deactive</button>
          </form>
          <form method="post" action="/shop/reward/assign" id="assignRewardForm">
            <input type="hidden" name="childId" id="assignChildHiddenId" value="<%= activeChild.id %>">
            <input type="hidden" name="rewardId" id="assignRewardHiddenId">
            <button type="submit" class="btn btn-primary" data-confirm="Set this reward to active with unlimited quantity?">Active</button>
          </form>
        </div>
      </div>
    </div>
  </div>
<% } %>

<div id="page-toast" class="d-none" data-message="<%= message || '' %>" data-error="<%= error || '' %>"></div>
<%- include('../../partials/script', { src: '/js/pages/parent_scope_tabs.js', type: 'module' }) %>
<%- include('../../partials/script', { src: '/js/pages/shop_assign.js', type: 'module' }) %>


