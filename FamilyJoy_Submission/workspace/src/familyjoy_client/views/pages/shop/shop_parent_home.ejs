<%
layout = 'layouts/navigated_layout';
%>

<div class="pt-4 px-3 pb-0 h-100 d-flex flex-column overflow-hidden shop-parent-home-content">
  <div class="content-top mb-3">
    <div class="content-header">
      <h2 class="mb-1">Wish Warehouse</h2>
      <p class="text-muted mb-0">Shared wish warehouse for your family.</p>
    </div>
  </div>

  <%
    const minSlots = 9;
    const totalSlots = Math.max(rewards.length, minSlots);
  %>
  <div class="content-body border rounded bg-body-tertiary p-3 flex-grow-1 d-flex flex-column mb-3 overflow-hidden">
    <% if (!hasChildren) { %>
      <div class="h-100 d-flex align-items-center justify-content-center">
        <div class="border rounded-3 p-3 d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between gap-2 w-100" style="max-width: 420px;">
          <div>
            <div class="fw-semibold">No Child Member Yet</div>
            <div class="text-muted small">Add a child to start assigning rewards from your warehouse.</div>
          </div>
          <a href="/family" class="btn btn-primary btn-sm">Add Child</a>
        </div>
      </div>
    <% } else { %>
    <% if (parentScopeTabs && parentScopeTabs.length) { %>
      <div class="mb-3">
        <div class="fj-parent-tabs-wrap">
          <button
            class="btn btn-outline-secondary fj-parent-tabs-arrow"
            type="button"
            data-scope-tabs-scroll="left"
            aria-label="Scroll tabs left">
            <i class="bi bi-chevron-left"></i>
          </button>
          <div class="fj-parent-tabs-scroll" data-scope-tabs-scroll-container>
            <ul class="nav nav-tabs fj-parent-tabs-list" data-scope-tabs-list>
              <% parentScopeTabs.forEach(function(tab) { %>
                <li class="nav-item">
                  <a class="nav-link <%= tab.isActive ? 'active' : '' %>" href="<%= tab.href %>"><%= tab.label %></a>
                </li>
              <% }); %>
            </ul>
          </div>
          <button
            class="btn btn-outline-secondary fj-parent-tabs-arrow"
            type="button"
            data-scope-tabs-scroll="right"
            aria-label="Scroll tabs right">
            <i class="bi bi-chevron-right"></i>
          </button>
        </div>
      </div>
    <% } %>

    <div class="content-actions mb-3">
      <button class="btn btn-primary btn-lg w-100" type="button" data-bs-toggle="modal" data-bs-target="#createRewardModal">
        <i class="bi bi-plus-lg"></i> New Reward
      </button>
    </div>

      <div class="overflow-y-auto overflow-x-hidden shop-grid-scroll touch-scroll h-100">
        <div class="row row-cols-3 g-3" data-shop-grid-track>
          <% for (let i = 0; i < totalSlots; i += 1) {
               const reward = rewards[i];
             if (reward) { %>
          <div class="col">
            <div class="card h-100 shop-grid-cell" data-shop-grid-cell>
              <button
                type="button"
                class="btn w-100 h-100 p-0 border-0 text-reset"
                data-bs-toggle="modal"
                data-bs-target="#parentShopItemModal"
                data-item-id="<%= reward.id %>"
                data-item-name="<%= reward.name %>"
                data-item-description="<%= reward.description %>"
                data-item-price="<%= reward.price %>"
                data-item-icon-key="<%= reward.icon_key %>"
                data-item-icon-class="<%= reward.iconClass %>"
                data-item-status-label="<%= reward.statusLabel %>"
                data-item-inactive="<%= reward.isInactive ? '1' : '0' %>">
                <div class="card-body d-flex flex-column text-center h-100">
                  <div class="fw-semibold small text-truncate mb-3"><%= reward.name %></div>
                  <div class="flex-grow-1 d-flex align-items-center justify-content-center">
                    <i class="bi <%= reward.iconClass %> fs-2"></i>
                  </div>
                  <div class="d-flex align-items-center justify-content-center gap-1 fw-semibold mt-3">
                    <i class="bi bi-gem fj-crystal-icon"></i>
                    <span><%= reward.price %></span>
                  </div>
                </div>
              </button>
            </div>
          </div>
        <% } else { %>
          <div class="col">
            <div class="card h-100 shop-grid-cell" data-shop-grid-cell>
              <div class="card-body h-100"></div>
            </div>
          </div>
        <% } } %>
      </div>
    </div>
    <% } %>
  </div>
</div>

<div class="modal fade" id="parentShopItemModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="parentShopItemTitle">Reward</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="d-flex flex-column align-items-center text-center gap-2">
          <i id="parentShopItemIcon" class="bi bi-gift fs-1"></i>
          <p class="text-muted small mb-0" id="parentShopItemDescription"></p>
          <div class="d-flex align-items-center gap-1 fw-semibold">
            <i class="bi bi-gem fj-crystal-icon"></i>
            <span id="parentShopItemPrice"></span>
          </div>
          <div id="parentShopItemStatusWrap" class="d-none">
            <span id="parentShopItemStatus" class="badge text-bg-secondary"></span>
          </div>
        </div>
      </div>
      <div class="modal-footer justify-content-between">
        <form method="post" action="" id="parentShopDeleteForm">
          <button class="btn btn-outline-danger" type="submit" data-confirm="Delete this reward from shop? Existing backpack/wish items will still work until consumed.">Delete</button>
        </form>
        <div class="d-flex gap-2">
          <button type="button" class="btn btn-primary" id="parentShopEditFromDetail">Edit</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Create Reward Modal -->
<div class="modal fade" id="createRewardModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Create Reward</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form method="post" action="/shop/reward/create" id="createRewardForm">
        <div class="modal-body">
          <%- include('../../partials/shop_reward_form_fields', {
            formId: 'createRewardForm',
            nameId: '',
            descriptionId: '',
            priceId: '',
            iconInputId: 'createIconKey',
            iconPreviewId: 'createIconPreview',
            descriptionValue: 'Magic Gift'
          }) %>
        </div>
        <div class="modal-footer">
          <button type="submit" class="btn btn-primary">Create</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Edit Reward Modal -->
<div class="modal fade" id="editRewardModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Edit Reward</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form method="post" action="" id="editRewardForm">
        <div class="modal-body">
          <%- include('../../partials/shop_reward_form_fields', {
            formId: 'editRewardForm',
            nameId: 'editRewardName',
            descriptionId: 'editRewardDescription',
            priceId: 'editRewardPrice',
            iconInputId: 'editRewardIcon',
            iconPreviewId: 'editIconPreview',
            descriptionValue: ''
          }) %>
        </div>
        <div class="modal-footer">
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div id="page-toast" class="d-none" data-message="<%= message || '' %>" data-error="<%= error || '' %>"></div>
<%- include('../../partials/script', { src: '/js/pages/parent_scope_tabs.js', type: 'module' }) %>
<%- include('../../partials/script', { src: '/js/pages/parent_shop.js', type: 'module' }) %>
