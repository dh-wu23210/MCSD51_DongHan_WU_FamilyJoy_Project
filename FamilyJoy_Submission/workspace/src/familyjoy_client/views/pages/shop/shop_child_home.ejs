<%
layout = 'layouts/navigated_layout';
%>

<div class="px-3 pt-4 pb-0 h-100 d-flex flex-column overflow-hidden">
  <div class="content-top">
    <div class="content-header mb-3">
      <h2 class="mb-1">Shop</h2>
      <p class="text-muted mb-0">Use crystals to buy rewards from the wish warehouse.</p>
    </div>
  </div>

  <%
    const minSlots = 9;
    const totalSlots = Math.max(rewards.length, minSlots);
    const shouldScroll = rewards.length > minSlots;
  %>
  <div class="content-body border rounded bg-body-tertiary p-3 flex-grow-1 d-flex flex-column mb-3">
    <div class="<%= shouldScroll ? 'overflow-y-auto overflow-x-hidden shop-grid-scroll touch-scroll h-100' : 'overflow-hidden h-100' %>" data-shop-grid-scroll data-should-scroll="<%= shouldScroll ? '1' : '0' %>">
      <div class="row row-cols-3 g-3" data-shop-grid-track>
        <% for (let i = 0; i < totalSlots; i += 1) {
             const item = rewards[i];
             if (item) { %>
          <div class="col">
            <div class="card h-100 shop-grid-cell <%= item.cardClass %>" data-shop-grid-cell>
              <button
                type="button"
                class="btn w-100 h-100 p-0 border-0 text-reset"
                data-bs-toggle="modal"
                data-bs-target="#childShopItemModal"
                data-item-id="<%= item.id %>"
                data-item-name="<%= item.name %>"
                data-item-description="<%= item.description %>"
                data-item-icon-class="<%= item.iconClass %>"
                data-item-price="<%= item.price %>"
                data-item-quantity-label="<%= item.quantityLabel %>"
                data-item-disabled="<%= item.isDisabled ? '1' : '0' %>"
                data-item-confirm-text="<%= item.confirmText %>">
                <div class="card-body d-flex flex-column text-center h-100">
                  <div class="fw-semibold small text-truncate mb-3"><%= item.name %></div>
                  <div class="flex-grow-1 d-flex align-items-center justify-content-center">
                    <i class="bi <%= item.iconClass %> fs-2"></i>
                  </div>
                  <div class="d-flex align-items-center justify-content-center gap-1 fw-semibold mt-3">
                    <i class="bi bi-gem fj-crystal-icon"></i>
                    <span><%= item.price %></span>
                  </div>
                </div>
              </button>
            </div>
          </div>
        <% } else { %>
          <div class="col">
            <div class="card h-100 shop-grid-cell" data-shop-grid-cell>
              <div class="card-body h-100"></div>
            </div>
          </div>
        <% } } %>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="childShopItemModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-md">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="childShopItemTitle">Item</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form method="post" action="" id="childShopBuyForm">
        <div class="modal-body">
          <div class="d-flex flex-column align-items-center text-center gap-2">
            <i id="childShopItemIcon" class="bi bi-gift fs-1"></i>
            <p class="text-muted small mb-0" id="childShopItemDescription"></p>
            <div class="d-flex align-items-center gap-1 fw-semibold">
              <i class="bi bi-gem fj-crystal-icon"></i>
              <span id="childShopItemPrice"></span>
            </div>
            <div class="text-muted small" id="childShopItemQuantity"></div>
          </div>
        </div>
        <div class="modal-footer">
          <button
            type="submit"
            class="btn btn-primary"
            id="childShopBuyButton">
            Buy
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<div id="page-toast" class="d-none" data-message="<%= message || '' %>" data-error="<%= error || '' %>"></div>
<%- include('../../partials/script', { src: '/js/pages/child_shop.js', type: 'module' }) %>


