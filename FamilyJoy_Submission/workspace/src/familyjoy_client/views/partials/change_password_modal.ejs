<% if (changePassword.isForced) { %>
  <div class="modal-backdrop fade show"></div>
<% } %>
<div
  class="modal <%= changePassword.isForced ? 'show d-block' : 'fade' %> app-device-modal"
  id="changePasswordModal"
  tabindex="-1"
  aria-hidden="<%= changePassword.isForced ? 'false' : 'true' %>"
  aria-modal="<%= changePassword.isForced ? 'true' : 'false' %>"
  role="dialog"
  data-bs-backdrop="<%= changePassword.isForced ? 'static' : 'true' %>"
  data-bs-keyboard="<%= changePassword.isForced ? 'false' : 'true' %>">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><%= changePassword.titleText %></h5>
        <% if (changePassword.showClose) { %>
          <a href="/profile" class="btn-close" aria-label="Close" data-bs-dismiss="modal"></a>
        <% } %>
      </div>
      <div class="modal-body">
        <% if (changePassword.isForced) { %>
          <p class="text-muted">You must set a new password before continuing.</p>
        <% } %>

        <% if (changePassword.hasError) { %>
          <div class="alert alert-danger">
            <%= changePassword.errorMessage %>
          </div>
        <% } %>

        <form method="post" action="/profile/change-password" id="changePasswordForm" data-is-forced="<%= changePassword.isForcedAttr %>">
          <% if (changePassword.showCurrentPassword) { %>
            <div class="mb-3">
              <label class="form-label">Current Password</label>
              <input name="currentPassword" type="password" class="form-control" required>
            </div>
          <% } %>
          <div class="mb-3">
            <label class="form-label">New Password</label>
            <input name="password" id="passwordInput" type="password" class="form-control" required minlength="6">
            <div class="form-text">At least 6 characters</div>
          </div>
          <div class="mb-3">
            <label class="form-label">Confirm New Password</label>
            <input name="password2" id="confirmPasswordInput" type="password" class="form-control" required minlength="6">
          </div>
          <div class="d-flex justify-content-end gap-2">
            <% if (changePassword.showCancel) { %>
              <a href="/profile" class="btn btn-secondary">Cancel</a>
            <% } %>
            <button class="btn btn-primary" type="submit" id="changePasswordBtn"><%= changePassword.submitLabel %></button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var modalEl = document.getElementById('changePasswordModal');
    if (!modalEl) return;

    // Move to top-level modal root to avoid clipping inside page containers.
    var modalRoot = document.getElementById('modal-root');
    if (modalRoot && modalEl.parentNode !== modalRoot) {
      modalRoot.appendChild(modalEl);
    }

    if (<%= changePassword.isForced ? "true" : "false" %>) {
      // Forced flow renders modal as visible by default (show d-block),
      // so users can never miss it even if modal init is interrupted.
      modalEl.style.setProperty('z-index', '1100', 'important');
      var forcedBackdrops = document.querySelectorAll('.modal-backdrop');
      var forcedBackdrop = forcedBackdrops[forcedBackdrops.length - 1];
      if (forcedBackdrop) {
        forcedBackdrop.style.setProperty('z-index', '1000', 'important');
      }
      return;
    }

    var modal = bootstrap.Modal.getOrCreateInstance(modalEl, {
      backdrop: <%= changePassword.isForced ? "'static'" : "true" %>,
      keyboard: <%= changePassword.isForced ? "false" : "true" %>
    });

    modalEl.addEventListener('shown.bs.modal', function () {
      modalEl.style.setProperty('z-index', '1100', 'important');
      var backdrops = document.querySelectorAll('.modal-backdrop');
      var latestBackdrop = backdrops[backdrops.length - 1];
      if (latestBackdrop) {
        latestBackdrop.style.setProperty('z-index', '1000', 'important');
      }
    });

    modal.show();
  });
</script>
