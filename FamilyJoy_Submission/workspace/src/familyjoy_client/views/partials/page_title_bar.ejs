<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h2 class="mb-1"><%= title %></h2>
    <% if (subtitle) { %>
      <p class="text-muted mb-0"><%= subtitle %></p>
    <% } %>
  </div>
  <% if (rightActions) { %>
    <div class="d-flex gap-2">
      <%- rightActions %>
    </div>
  <% } %>
</div>
